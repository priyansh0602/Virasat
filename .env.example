# ─────────────────────────────────────────────────────────────────────────────
# Virasat — Heritage Knowledge Base  |  Environment Variables
# Copy this file to `.env` and fill in your Supabase project credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → anon (public) key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional but recommended: app URL used for OAuth redirect (must include http/https)
# Examples: http://localhost:3000 or https://your-app.vercel.app
VITE_APP_URL=http://localhost:3000
